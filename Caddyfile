# Caddyfile for broiler.dev static site.
# Replaces nginx. Runs non-root inside the caddy:alpine image.
{
	admin off
	persist_config off
	auto_https off
}

:8080 {
	root * /srv
	encode zstd gzip

	# Security-Header für alle Antworten. HSTS-Preload setzt voraus, dass
	# https://broiler.dev/ konsequent über HTTPS ausgeliefert wird (TLS-
	# Terminierung übernimmt der DigitalOcean-LB, deshalb hier ohne
	# Caddy-eigenes auto_https). Die CSP listet die externen Origins
	# explizit auf, die index.html und ClipEmbed.tsx aktuell brauchen
	# (Google Fonts, Google AdSense + Consent-Tag-Manager, Twitch-Embed).
	# `frame-ancestors 'none'` ersetzt im modernen Browser X-Frame-Options;
	# letzteres bleibt als Fallback für sehr alte UAs.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://pagead2.googlesyndication.com https://*.googlesyndication.com https://*.google.com https://*.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; frame-src https://clips.twitch.tv https://*.googlesyndication.com https://*.google.com https://*.doubleclick.net; connect-src 'self' https://api.broiler.dev; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
	}

	# Long-term cache for hashed/static assets (set before the handlers so
	# it applies regardless of SPA fallback rewrite).
	@assets path *.js *.css *.woff2 *.woff *.svg *.png *.jpg *.jpeg *.gif *.ico
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Crawler ohne (zuverlässiges) JS-Rendering an den Open-Graph-Renderer
	# der API umleiten. Drei Gruppen werden erfasst:
	#   1. Social-Crawler (Link-Vorschauen): facebook, twitter, discord,
	#      whatsapp, linkedin, slack, telegram, reddit, mastodon, bluesky,
	#      threads, embedly, …
	#   2. Suchmaschinen ohne JS: bingbot, yandex, duckduckbot, baidu-
	#      spider, applebot, adidxbot.
	#   3. AI-Crawler (kein JS): gptbot, oai-searchbot, chatgpt-user,
	#      perplexitybot, claudebot, anthropic-ai, ccbot.
	# Googlebot fehlt bewusst — Google rendert SPAs zuverlässig und sieht
	# beim Blog dann den Markdown-Volltext statt nur des OG-Stub-Excerpts.
	# Wenn das in der Search Console „Rendered HTML" jemals auseinander-
	# läuft, kann Googlebot nachträglich in die Liste.
	#
	# Echte Nutzer (andere User-Agents) fallen in den SPA-Handler unten.
	# Die `handle`-Blöcke sind sich gegenseitig ausschließend, daher kein
	# Doppel-Handling.
	@og_bots {
		path /streamclips/clip/* /blog/*
		header_regexp User-Agent (?i)(facebookexternalhit|facebot|twitterbot|discordbot|whatsapp|linkedinbot|slackbot|telegrambot|pinterest|redditbot|vkshare|skypeuripreview|embedly|applebot|mastodon|bsky|threads|bingbot|adidxbot|yandex(bot|images)?|duckduckbot|baiduspider|gptbot|oai-searchbot|chatgpt-user|perplexitybot|claudebot|claude-web|anthropic-ai|ccbot)
	}
	handle @og_bots {
		rewrite * /prod/og{path}
		reverse_proxy https://api.broiler.dev {
			header_up Host api.broiler.dev
		}
	}

	# Dynamische sitemap.xml von der API (enthält auch alle Clip-/Artikel-URLs)
	# statt einer statischen Datei. robots.txt + GSC zeigen weiterhin auf
	# https://broiler.dev/sitemap.xml.
	handle /sitemap.xml {
		rewrite * /prod/sitemap.xml
		reverse_proxy https://api.broiler.dev {
			header_up Host api.broiler.dev
		}
	}

	# RSS-Feed für den Blog (analog zur sitemap.xml). Muss VOR dem SPA-
	# Handler stehen, sonst greift try_files → index.html und der Reader
	# bekommt HTML statt RSS.
	handle /blog/rss.xml {
		rewrite * /prod/blog/rss.xml
		reverse_proxy https://api.broiler.dev {
			header_up Host api.broiler.dev
		}
	}

	# Alles andere: SPA-Auslieferung mit Fallback. Das `route` erzwingt
	# sequentielle Ausführung, damit der no-cache-Header nach dem try_files
	# greift (auch /blog → /index.html bekommt ihn).
	handle {
		route {
			try_files {path} {path}.html {path}/ /index.html

			@shell path *.html
			header @shell Cache-Control "no-cache"

			file_server
		}
	}

	handle_errors {
		@notfound expression `{http.error.status_code} == 404`
		rewrite @notfound /huh.html
		file_server
	}
}
