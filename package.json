{
  "name": "web",
  "version": "1.0.0",
  "description": "broiler.dev",
  "main": "index.js",
  "scripts": {
    "dev": "npx vite --host",
    "build": "npx vite build",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "preview": "vite preview --port 4173 --strictPort",
    "a11y": "axe http://localhost:4173 --exit",
    "a11y:ci": "start-server-and-test preview http://localhost:4173 a11y",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3roiler/web.git"
  },
  "author": "3roiler",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/3roiler/web/issues"
  },
  "homepage": "https://broiler.dev/",
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "start-server-and-test": "^3.0.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "@sentry/react": "^10.53.1",
    "@tailwindcss/vite": "^4.2.4",
    "@uiw/react-codemirror": "^4.25.10",
    "@uiw/react-md-editor": "^4.1.0",
    "axios": "^1.15.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0"
  }
}
